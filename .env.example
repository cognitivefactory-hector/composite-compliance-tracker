# Copy to .env for local overrides. .env is gitignored — NEVER commit secrets.

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# DJANGO_CSRF_TRUSTED_ORIGINS=https://composite.hector-garza.com

# Database (docker-compose provides this default; Render injects its own)
DATABASE_URL=postgres://postgres:postgres@db:5432/composite

# Optional Claude assist (M6). Leave blank to disable — the app is fully usable
# without it. NEVER commit a real key.
ANTHROPIC_API_KEY=
